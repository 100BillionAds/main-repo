# =============================================
# 백억광고 (10badv) 환경변수 템플릿
# =============================================
# 이 파일을 복사하여 .env.local (개발) 또는 Vercel 대시보드 (프로덕션)에 설정하세요.
# cp .env.example .env.local
#
# ⚠️ 실제 시크릿 값을 이 파일에 넣지 마세요! (.env.example은 Git에 커밋됩니다)
# ⚠️ 프로덕션에서는 반드시 Vercel 대시보드 > Settings > Environment Variables에서 설정하세요.

# =============================================
# 1. 데이터베이스 (무료 우선: TiDB Serverless 권장)
# =============================================
# 클로즈드 테스트 모드 (비용 0원 운영 임시 모드):
# - true로 설정하고 DATABASE_*를 비워두면
#   프로덕션에서 쓰기 기능(회원가입/결제/생성·수정 API)이 자동 차단됩니다.
# - 서버 전용 플래그(CLOSED_BETA_MODE)도 함께 지원합니다.
#
CLOSED_BETA_MODE=false
NEXT_PUBLIC_CLOSED_BETA_MODE=false
#
# 옵션 A) 개별 필드 입력
DATABASE_HOST=your-mysql-host
DATABASE_PORT=3306
DATABASE_USER=your-mysql-user
DATABASE_PASSWORD=your-mysql-password
DATABASE_NAME=tenbadv
# 옵션 B) 단일 URL 입력 (예: mysql://user:pass@host:4000/tenbadv)
DATABASE_URL=
# 서버리스 MySQL(TiDB/PlanetScale 등) 연결 시 TLS 권장
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=true
# 필요 시 CA 인증서 본문을 입력 (선택)
DATABASE_SSL_CA=

# [무료 MySQL 발급 방법 - TiDB Serverless 예시]
# 1) https://tidbcloud.com 접속 후 Serverless Cluster 생성
# 2) Connect 정보에서 host, port, user, password, database 확인
# 3) DATABASE_URL 또는 DATABASE_* 항목에 반영
# 4) 초기 스키마는 애플리케이션이 자동 생성 (initializeDatabase)
# 5) 로컬 개발은 docker-compose의 MySQL(3306) 사용 가능

# =============================================
# 2. NextAuth 인증
# =============================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-secret-here

# [NEXTAUTH_SECRET 생성 방법]
# 터미널에서 아래 명령어 중 하나 실행:
#   openssl rand -base64 32
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# NEXTAUTH_URL은 Vercel 배포 시 자동 설정되므로 로컬 개발 시에만 http://localhost:3000 입력

# =============================================
# 3. PortOne 결제 (구 아임포트)
# =============================================
NEXT_PUBLIC_PORTONE_STORE_ID=store-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
NEXT_PUBLIC_PORTONE_CHANNEL_KEY=channel-key-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PORTONE_API_SECRET=your-portone-api-secret

# [개발 전용] mock 결제 검증 모드
# true로 설정하면 포트원 실결제 호출 없이 로컬 결제 검증 API 테스트가 가능합니다.
PORTONE_MOCK_MODE=false
NEXT_PUBLIC_PAYMENT_MOCK_MODE=false

# [PortOne 발급 방법]
# 1) https://admin.portone.io 회원가입 및 로그인
# 2) 결제 연동 → 연동 정보 → "스토어 ID" 확인 (NEXT_PUBLIC_PORTONE_STORE_ID)
# 3) 결제 연동 → 채널 관리 → 채널 추가 → PG사 선택 (이니시스, KG이니시스 등)
#    - 테스트/실연동 선택 후 → "채널 키" 확인 (NEXT_PUBLIC_PORTONE_CHANNEL_KEY)
# 4) 결제 연동 → API Keys → "V2 API Secret" 발급 (PORTONE_API_SECRET)
#
# 테스트 모드: PG사와 별도 계약 없이 테스트 결제 가능 (store- 접두사가 테스트용)
# 실결제 모드: PG사(이니시스 등)와 가맹점 계약 필요
#
# 실결제 전환 시 필요서류:
#   - 사업자등록증
#   - 통장사본 (정산 입금용)
#   - 대표자 신분증 사본

# =============================================
# 4. 파일 스토리지 (무료 우선: Cloudinary)
# =============================================
STORAGE_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# [Cloudinary 무료 플랜 설정 방법]
# 1) https://cloudinary.com 가입
# 2) Dashboard에서 Cloud name / API Key / API Secret 확인
# 3) 위 CLOUDINARY_* 환경변수에 입력
# 4) 업로드 API는 서버 서명 방식으로 동작 (클라이언트 시크릿 노출 없음)

# 선택 사항: 기존 S3를 계속 쓸 경우에만 사용
# STORAGE_PROVIDER=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=ap-northeast-2

# =============================================
# 5. Socket.IO (실시간 채팅)
# =============================================
NEXT_PUBLIC_SOCKET_URL=http://localhost:3000

# [Socket.IO 서버 안내]
# Vercel은 WebSocket을 지원하지 않으므로, 실시간 채팅 사용 시:
#   방법 1) Railway.app (https://railway.app) — 무료 플랜 월 $5 크레딧
#   방법 2) Fly.io (https://fly.io) — 무료 VM 제공
# 해당 서버에서 server.js를 실행하고, URL을 NEXT_PUBLIC_SOCKET_URL에 입력
#
# 로컬 개발 시: http://localhost:3000 (server.js가 Socket.IO 내장)

# =============================================
# 6. 소셜 로그인 (추후 구현 예정)
# =============================================
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# KAKAO_CLIENT_ID=
# KAKAO_CLIENT_SECRET=
# NAVER_CLIENT_ID=
# NAVER_CLIENT_SECRET=

# [소셜 로그인 발급 방법]
# Google: https://console.cloud.google.com → API 및 서비스 → 사용자 인증 정보 → OAuth 2.0 클라이언트 ID 생성
#         - 승인된 리디렉션 URI: https://your-domain.vercel.app/api/auth/callback/google
# Kakao: https://developers.kakao.com → 앱 등록 → 앱 키 → REST API 키 + 보안 키(Secret)
#         - 카카오 로그인 활성화 + Redirect URI 설정
# Naver: https://developers.naver.com → 애플리케이션 등록 → Client ID + Secret
#         - API 권한: 네아로(네이버 아이디로 로그인)

# =============================================
# 7. 에러 모니터링 (선택 — 프로덕션 권장)
# =============================================
# SENTRY_DSN=

# [Sentry 설정]
# 1) https://sentry.io 무료 가입 → 프로젝트 생성 (platform: Next.js)
# 2) DSN 복사하여 SENTRY_DSN에 입력
# 3) npm install @sentry/nextjs && npx @sentry/wizard@latest -i nextjs
