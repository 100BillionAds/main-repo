# Example environment variables for local development
# Copy to .env.local and fill values as needed

# Public API base (used in client code)
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Database (MySQL)
DATABASE_HOST=localhost
DATABASE_USER=root
DATABASE_PASSWORD=your_password
DATABASE_NAME=10badv

# Authentication
NEXTAUTH_SECRET=generate-a-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# PortOne (포트원) 결제 API
NEXT_PUBLIC_PORTONE_STORE_ID=your-store-id
NEXT_PUBLIC_PORTONE_CHANNEL_KEY=your-channel-key
PORTONE_API_SECRET=your-api-secret

# AWS S3 (파일 업로드)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=your-bucket-name
AWS_REGION=ap-northeast-2

# Socket.io
NEXT_PUBLIC_SOCKET_URL=http://localhost:3000

