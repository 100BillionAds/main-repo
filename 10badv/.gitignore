# =============================================
# 백억광고 (10badv) - .gitignore
# =============================================

# ----- OS -----
.DS_Store
Thumbs.db

# ----- Node -----
node_modules/

# ----- Next.js -----
.next/
out/
build/
dist/
.turbo/
*.tsbuildinfo
next-env.d.ts

# ----- Environment (보안!) -----
.env
.env.local
.env.production
.env.development
.env.test
.env*.local
!.env.example

# ----- Editor -----
.vscode/
.idea/
*.swp
*.swo
*~

# ----- Testing -----
coverage/
*.lcov
.nyc_output/

# ----- Cache -----
.cache/
.eslintcache

# ----- Logs -----
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ----- Uploads (S3 이관됨) -----
public/uploads/**
!public/uploads/.gitkeep
!public/uploads/**/.gitkeep

# ----- Secrets / Keys -----
*.pem
*.key

# ----- Vercel -----
.vercel/

# ----- Generated -----
src/generated/prisma

# ----- Package manager -----
.pnp
.pnp.js
