# =============================================
# 백억광고 (10badv) 로컬 개발 환경변수
# =============================================
# ⚠️ 이 파일은 절대로 Git에 커밋하지 마세요!
# 
# 설정 방법:
# 1. 이 파일을 .env.local로 복사: cp .env.local.template .env.local
# 2. 실제 값으로 교체
# 3. 서버 재시작: npm run dev

# =============================================
# 1. 데이터베이스 (MySQL)
# =============================================
DATABASE_HOST=localhost
DATABASE_USER=root
DATABASE_PASSWORD=
DATABASE_NAME=10badv

# =============================================
# 2. NextAuth 인증
# =============================================
NEXTAUTH_URL=http://localhost:3000
# 아래 명령어로 시크릿 생성:
# openssl rand -base64 32
NEXTAUTH_SECRET=your-development-secret-change-in-production

# =============================================
# 3. PortOne 결제 (테스트 모드)
# =============================================
# https://admin.portone.io 에서 테스트용 키 발급
NEXT_PUBLIC_PORTONE_STORE_ID=
NEXT_PUBLIC_PORTONE_CHANNEL_KEY=
PORTONE_API_SECRET=

# 로컬 결제 플로우 테스트용 (실결제 호출 없이 /api/payments/verify 통과)
PORTONE_MOCK_MODE=true
NEXT_PUBLIC_PAYMENT_MOCK_MODE=true

# =============================================
# 4. AWS S3 (선택 - 로컬 파일 저장소 사용 가능)
# =============================================
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_REGION=ap-northeast-2

# =============================================
# 5. Socket.IO
# =============================================
NEXT_PUBLIC_SOCKET_URL=http://localhost:3000
