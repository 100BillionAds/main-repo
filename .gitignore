# =============================================
# 백억광고 (10badv) - .gitignore
# =============================================

# ----- OS -----
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db

# ----- Node / Dependencies -----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ----- Next.js -----
.next/
out/
build/
dist/
.turbo/
*.tsbuildinfo
next-env.d.ts

# ----- Vercel -----
.vercel/
.now/

# ----- Environment (보안!) -----
.env
.env.local
.env.production
.env.development
.env.test
.env*.local
.env.development.local
.env.production.local
.env.test.local
local.env
# .env.example은 커밋 허용
!.env.example
!**/.env.example

# ----- Secrets / Keys -----
*.pem
*.key
*.p12

# ----- Logs -----
logs/
*.log
*.pid
*.seed
*.pid.lock

# ----- Editor / IDE -----
.vscode/
.idea/
*.sublime-workspace
*.sublime-project
*.swp
*.swo
*~

# ----- Testing / Coverage -----
coverage/
.nyc_output/
*.lcov

# ----- Cache -----
.cache/
.eslintcache

# ----- Uploads (사용자 파일 → S3 이관됨) -----
**/public/uploads/**
!**/public/uploads/.gitkeep
!**/public/uploads/**/.gitkeep

# ----- Generated -----
**/generated/prisma

.env/*